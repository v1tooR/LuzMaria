{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/content/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/product/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|EB Garamond|Inter|Pinyon Script))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, EB Garamond, Inter, Pinyon Script."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|wine|outline)$/]",
        "message": "<Badge> tone must be one of 'gold' | 'wine' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|fullWidth|disabled|type|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, fullWidth, disabled, type, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|onIvory)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'onIvory'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|answer|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<FaqItem> doesn't accept that prop. Declared props: question, answer, defaultOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|type|placeholder|value|onChange|required|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, id, type, placeholder, value, onChange, required."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnateFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|pad|key|ref|className|style|children)$/]",
        "message": "<OrnateFrame> doesn't accept that prop. Declared props: children, pad."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|price|image|imageAlt|badge|phone|message|ctaLabel|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, description, price, image, imageAlt, badge, phone, message, ctaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|width|key|ref|className|style|children)$/]",
        "message": "<SectionDivider> doesn't accept that prop. Declared props: variant, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionDivider'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:line|node)$/]",
        "message": "<SectionDivider> variant must be one of 'line' | 'node'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepList'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|direction|key|ref|className|style|children)$/]",
        "message": "<StepList> doesn't accept that prop. Declared props: steps, direction."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepList'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<StepList> direction must be one of 'horizontal' | 'vertical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|wine|muted)$/]",
        "message": "<Tag> tone must be one of 'gold' | 'wine' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|placeholder|rows|value|onChange|required|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, id, placeholder, rows, value, onChange, required."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhatsAppButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|message|phone|variant|size|fullWidth|key|ref|className|style|children)$/]",
        "message": "<WhatsAppButton> doesn't accept that prop. Declared props: children, message, phone, variant, size, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhatsAppButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|onIvory)$/]",
        "message": "<WhatsAppButton> variant must be one of 'primary' | 'secondary' | 'ghost' | 'onIvory'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhatsAppButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<WhatsAppButton> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
